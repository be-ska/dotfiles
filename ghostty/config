# theme
theme = Rose Pine

# font
font-family = "VictorMono NFM SemiBold"
font-size = 15

# icon (?)
macos-icon = custom-style
macos-icon-ghost-color = BCBEC4
macos-icon-screen-color = 26233A 

# disable ligatures
font-feature = -liga, -calt, -dlig

# fix cmd+
keybind = cmd+BracketRight=increase_font_size:1
